# Copy to azure-foundry-proxy.env (gitignored) or export in your shell.
# Required: end with /openai/v1 — do NOT add /responses (OpenClaw appends that).
AZURE_FOUNDRY_TARGET_BASE_URL=https://YOUR_RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT/openai/v1

# OpenClaw models.providers.*.baseUrl must be http://127.0.0.1:2929 only (no /openai/v1).

# Optional:
AZURE_FOUNDRY_PROXY_PORT=2929
AZURE_FOUNDRY_PROXY_BIND=127.0.0.1
# AZURE_FOUNDRY_PROXY_VERBOSE=1
# AZURE_FOUNDRY_PROXY_STRIP_TOOLS=1
